---
interface Props {
  name: string;
  src?: string;
  size?: number;
}

const { name, src, size = 80 } = Astro.props;
const initials = name.split(' ').map(n => n[0]).join('').toUpperCase();
---

<div class="photo" style={`width: ${size}px; height: ${size}px;`}>
  {src ? (
    <img src={src} alt={name} width={size} height={size} />
  ) : (
    <div class="placeholder">{initials}</div>
  )}
</div>

<style>
  .photo {
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
  }

  .photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--text-secondary);
    font-weight: 600;
    font-size: 1.5rem;
  }
</style>
