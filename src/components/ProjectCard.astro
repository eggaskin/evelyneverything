---
import ProjectLinks from './ProjectLinks.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  slug: string;
  tags?: string[];
  links?: { label: string; url: string }[];
  image?: string;
  compact?: boolean;
}

const { title, description, pubDate, slug, tags, links, image, compact = false } = Astro.props;

const dateStr = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
});
---

<article class:list={['project-card', { 'project-card--compact': compact }]}>
  <a href={`/projects/${slug}`} class="card-link">
    {image && (
      <div class="card-image">
        <img src={image} alt={title} loading="lazy" />
      </div>
    )}
    <div class="card-content">
      <time datetime={pubDate.toISOString()}>{dateStr}</time>
      <h3>{title}</h3>
      <p>{description}</p>
      {tags && tags.length > 0 && (
        <div class="tags">
          {tags.map(tag => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      )}
      {links && links.length > 0 && (
        <div class="links">
          <ProjectLinks links={links} />
        </div>
      )}
    </div>
  </a>
</article>

<style>
  .project-card {
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: border-color 0.15s ease;
  }

  .project-card:hover {
    border-color: var(--accent);
  }

  .card-link {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
  }

  .card-link:hover {
    color: inherit;
  }

  .card-image img {
    width: 100%;
    height: 200px;
    object-fit: cover;
  }

  .card-content {
    padding: 1.25rem;
  }

  time {
    font-size: 0.8rem;
    color: var(--text-secondary);
  }

  h3 {
    margin: 0.5rem 0 0.35rem;
    color: var(--text);
  }

  p {
    font-size: 0.95rem;
    color: var(--text-secondary);
    margin-bottom: 0.75rem;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 0.75rem;
  }

  .links {
    margin-top: 0.5rem;
  }

  /* Compact variant for resume */
  .project-card--compact .card-image img {
    height: 140px;
  }

  .project-card--compact .card-content {
    padding: 1rem;
  }
</style>
