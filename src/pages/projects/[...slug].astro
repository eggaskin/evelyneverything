---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectLinks from '../../components/ProjectLinks.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(project => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);

const dateStr = project.data.pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={`${project.data.title} | Projects`} description={project.data.description} variant="blog">
  <article class="container">
    <header class="project-header">
      <time datetime={project.data.pubDate.toISOString()}>{dateStr}</time>
      <h1>{project.data.title}</h1>
      <p class="description">{project.data.description}</p>
      {project.data.tags && project.data.tags.length > 0 && (
        <div class="tags">
          {project.data.tags.map(tag => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      )}
      {project.data.links && project.data.links.length > 0 && (
        <div class="links">
          <ProjectLinks links={project.data.links} />
        </div>
      )}
    </header>
    {project.data.image && (
      <div class="project-image">
        <img src={project.data.image} alt={project.data.title} />
      </div>
    )}
    <div class="prose">
      <Content />
    </div>
    <div class="back-link">
      <a href="/projects">&larr; All projects</a>
    </div>
  </article>
</BaseLayout>

<style>
  .project-header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
  }

  time {
    font-size: 0.85rem;
    color: var(--text-secondary);
  }

  h1 {
    margin: 0.75rem 0 0.5rem;
    font-size: 2rem;
  }

  .description {
    font-size: 1.1rem;
    color: var(--text-secondary);
    margin-bottom: 0.75rem;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 1rem;
  }

  .links {
    margin-top: 0.5rem;
  }

  .project-image {
    margin-bottom: 2rem;
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .project-image img {
    width: 100%;
    height: auto;
  }

  .back-link {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }

  .back-link a {
    font-size: 0.9rem;
    color: var(--text-secondary);
    text-decoration: none;
  }

  .back-link a:hover {
    color: var(--accent);
  }
</style>
